{
  "openapi": "3.1.0",
  "info": {
    "title": "Library App - library-service API",
    "description": "Frontend-facing API for the Library App: catalogue, lending, reservations/waitlist, payments, user profiles and admin.",
    "contact": {
      "name": "Library App"
    },
    "version": "v1"
  },
  "servers": [
    {
      "url": "http://localhost:8080",
      "description": "Generated server url"
    }
  ],
  "security": [
    {
      "bearerAuth": []
    }
  ],
  "tags": [
    {
      "name": "Users",
      "description": "Self-service profile and borrowing history"
    },
    {
      "name": "Notifications",
      "description": "Live notifications (e.g. a waitlisted book becoming available)"
    },
    {
      "name": "Books",
      "description": "Catalogue browsing and management"
    },
    {
      "name": "Payments",
      "description": "Late fees, reservation fees"
    },
    {
      "name": "Reservations",
      "description": "Waitlist for books that are fully checked out"
    },
    {
      "name": "Admin",
      "description": "User role and user-group administration (ADMIN only)"
    },
    {
      "name": "Lending",
      "description": "Checking books in and out at the lending desk"
    },
    {
      "name": "Auth",
      "description": "Account creation and login"
    }
  ],
  "paths": {
    "/api/books/{id}": {
      "get": {
        "tags": [
          "Books"
        ],
        "summary": "Get a single book by id",
        "operationId": "getBook",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int64"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/BookDto"
                }
              }
            }
          }
        }
      },
      "put": {
        "tags": [
          "Books"
        ],
        "summary": "Update a book's catalogue details (MANAGER)",
        "operationId": "updateBook",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int64"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UpdateBookRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/BookDto"
                }
              }
            }
          }
        }
      },
      "delete": {
        "tags": [
          "Books"
        ],
        "summary": "Remove a book from the catalogue (MANAGER)",
        "operationId": "removeBook",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int64"
            }
          }
        ],
        "responses": {
          "204": {
            "description": "No Content"
          }
        }
      }
    },
    "/api/admin/users/{userId}/role": {
      "put": {
        "tags": [
          "Admin"
        ],
        "summary": "Change a user's role",
        "operationId": "updateRole",
        "parameters": [
          {
            "name": "userId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int64"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UpdateUserRoleRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/UserDto"
                }
              }
            }
          }
        }
      }
    },
    "/api/admin/users/{userId}/group": {
      "put": {
        "tags": [
          "Admin"
        ],
        "summary": "Move a user to a different user group",
        "operationId": "updateGroup",
        "parameters": [
          {
            "name": "userId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int64"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UpdateUserGroupRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/UserDto"
                }
              }
            }
          }
        }
      }
    },
    "/api/reservations": {
      "post": {
        "tags": [
          "Reservations"
        ],
        "summary": "Join the waitlist for a book that's currently fully loaned out",
        "operationId": "reserve",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ReserveRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "201": {
            "description": "Created",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/ReservationDto"
                }
              }
            }
          }
        }
      }
    },
    "/api/payments/pay": {
      "post": {
        "tags": [
          "Payments"
        ],
        "summary": "Make a payment (mock - no real gateway is called)",
        "operationId": "pay",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/PaymentRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/PaymentDto"
                }
              }
            }
          }
        }
      }
    },
    "/api/payments/authorise/{paymentId}": {
      "post": {
        "tags": [
          "Payments"
        ],
        "summary": "Authorise a pending payment (MANAGER)",
        "operationId": "authorise",
        "parameters": [
          {
            "name": "paymentId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int64"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/PaymentDto"
                }
              }
            }
          }
        }
      }
    },
    "/api/notifications/{id}/read": {
      "post": {
        "tags": [
          "Notifications"
        ],
        "summary": "Mark one of my notifications as read",
        "operationId": "markRead",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int64"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/NotificationDto"
                }
              }
            }
          }
        }
      }
    },
    "/api/lending/return": {
      "post": {
        "tags": [
          "Lending"
        ],
        "summary": "Check a book back in, applying any late fee (MANAGER)",
        "operationId": "returnBook",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ReturnRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/BorrowingRecordDto"
                }
              }
            }
          }
        }
      }
    },
    "/api/lending/loan": {
      "post": {
        "tags": [
          "Lending"
        ],
        "summary": "Check a book out to a member (MANAGER)",
        "operationId": "loanBook",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/LoanRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/BorrowingRecordDto"
                }
              }
            }
          }
        }
      }
    },
    "/api/books": {
      "get": {
        "tags": [
          "Books"
        ],
        "summary": "Browse the full catalogue, or search by title (any authenticated user)",
        "operationId": "getAllBooks",
        "parameters": [
          {
            "name": "search",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "page",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "format": "int32",
              "default": 0
            }
          },
          {
            "name": "size",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "format": "int32",
              "default": 20
            }
          },
          {
            "name": "sortBy",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "default": "title"
            }
          },
          {
            "name": "direction",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "default": "asc"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/PageResponseBookDto"
                }
              }
            }
          }
        }
      },
      "post": {
        "tags": [
          "Books"
        ],
        "summary": "Add a new title to the catalogue (MANAGER)",
        "operationId": "addBook",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AddBookRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "201": {
            "description": "Created",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/BookDto"
                }
              }
            }
          }
        }
      }
    },
    "/api/auth/register": {
      "post": {
        "tags": [
          "Auth"
        ],
        "summary": "Create a new account",
        "operationId": "register",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RegisterRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "201": {
            "description": "Created",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/LoginResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/auth/login": {
      "post": {
        "tags": [
          "Auth"
        ],
        "summary": "Log in and receive a JWT",
        "operationId": "login",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/LoginRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/LoginResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/users/me": {
      "get": {
        "tags": [
          "Users"
        ],
        "summary": "My profile (active loans, reservations, balance)",
        "operationId": "me",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/UserProfileDto"
                }
              }
            }
          }
        }
      }
    },
    "/api/users/me/history": {
      "get": {
        "tags": [
          "Users"
        ],
        "summary": "My full borrowing history",
        "operationId": "myHistory",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "*/*": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/UserBorrowingHistoryDto"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/reservations/my-wishlist": {
      "get": {
        "tags": [
          "Reservations"
        ],
        "summary": "View my wishlist (active reservations)",
        "operationId": "myWishlist",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "*/*": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/ReservationDto"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/payments/history": {
      "get": {
        "tags": [
          "Payments"
        ],
        "summary": "View my payment history",
        "operationId": "history",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "*/*": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/PaymentDto"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/notifications/stream/{userId}": {
      "get": {
        "tags": [
          "Notifications"
        ],
        "summary": "Open a live SSE stream of my notifications",
        "operationId": "stream",
        "parameters": [
          {
            "name": "userId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int64"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "text/event-stream": {
                "schema": {
                  "$ref": "#/components/schemas/SseEmitter"
                }
              }
            }
          }
        }
      }
    },
    "/api/notifications/mine": {
      "get": {
        "tags": [
          "Notifications"
        ],
        "summary": "My unread notifications - catches up on whatever fired while I wasn't connected to the live stream",
        "operationId": "mine",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "*/*": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/NotificationDto"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/lending/my-loans": {
      "get": {
        "tags": [
          "Lending"
        ],
        "summary": "View my currently loaned books",
        "operationId": "myLoans",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "*/*": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/BorrowingRecordDto"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/admin/users": {
      "get": {
        "tags": [
          "Admin"
        ],
        "summary": "List all users with a given role",
        "operationId": "listByRole",
        "parameters": [
          {
            "name": "role",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "enum": [
                "USER",
                "MANAGER",
                "ADMIN"
              ]
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "*/*": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/UserDto"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/reservations/{id}": {
      "delete": {
        "tags": [
          "Reservations"
        ],
        "summary": "Cancel one of my reservations",
        "operationId": "cancel",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int64"
            }
          }
        ],
        "responses": {
          "204": {
            "description": "No Content"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "UpdateBookRequest": {
        "type": "object",
        "properties": {
          "title": {
            "type": "string"
          },
          "author": {
            "type": "string"
          },
          "publisher": {
            "type": "string"
          },
          "publishedYear": {
            "type": "integer",
            "format": "int32"
          },
          "genre": {
            "type": "string"
          },
          "totalCopies": {
            "type": "integer",
            "format": "int32",
            "minimum": 0
          }
        }
      },
      "BookDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int64"
          },
          "isbn": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "author": {
            "type": "string"
          },
          "publisher": {
            "type": "string"
          },
          "publishedYear": {
            "type": "integer",
            "format": "int32"
          },
          "genre": {
            "type": "string"
          },
          "totalCopies": {
            "type": "integer",
            "format": "int32"
          },
          "availableCopies": {
            "type": "integer",
            "format": "int32"
          },
          "status": {
            "type": "string",
            "enum": [
              "IN_STORE",
              "ON_LOAN",
              "RESERVED",
              "LOST"
            ]
          }
        }
      },
      "UpdateUserRoleRequest": {
        "type": "object",
        "properties": {
          "role": {
            "type": "string",
            "enum": [
              "USER",
              "MANAGER",
              "ADMIN"
            ]
          }
        },
        "required": [
          "role"
        ]
      },
      "UserDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int64"
          },
          "username": {
            "type": "string"
          },
          "email": {
            "type": "string"
          },
          "fullName": {
            "type": "string"
          },
          "phone": {
            "type": "string"
          },
          "address": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": [
              "ACTIVE",
              "SUSPENDED",
              "INACTIVE"
            ]
          },
          "role": {
            "type": "string",
            "enum": [
              "USER",
              "MANAGER",
              "ADMIN"
            ]
          },
          "passwordHash": {
            "type": "string",
            "writeOnly": true
          },
          "userGroupId": {
            "type": "integer",
            "format": "int64"
          }
        }
      },
      "UpdateUserGroupRequest": {
        "type": "object",
        "properties": {
          "userGroupId": {
            "type": "integer",
            "format": "int64"
          }
        },
        "required": [
          "userGroupId"
        ]
      },
      "ReserveRequest": {
        "type": "object",
        "properties": {
          "bookId": {
            "type": "integer",
            "format": "int64"
          }
        },
        "required": [
          "bookId"
        ]
      },
      "ReservationDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int64"
          },
          "userId": {
            "type": "integer",
            "format": "int64"
          },
          "bookId": {
            "type": "integer",
            "format": "int64"
          },
          "bookTitle": {
            "type": "string"
          },
          "reservationDate": {
            "type": "string",
            "format": "date-time"
          },
          "status": {
            "type": "string",
            "enum": [
              "RESERVED",
              "NOTIFIED",
              "FULFILLED",
              "CANCELLED",
              "EXPIRED"
            ]
          },
          "queuePosition": {
            "type": "integer",
            "format": "int32"
          }
        }
      },
      "PaymentRequest": {
        "type": "object",
        "properties": {
          "userId": {
            "type": "integer",
            "format": "int64"
          },
          "borrowingRecordId": {
            "type": "integer",
            "format": "int64"
          },
          "amount": {
            "type": "number"
          },
          "type": {
            "type": "string",
            "enum": [
              "LATE_FEE",
              "RESERVATION_FEE",
              "LOST_BOOK_CHARGE",
              "OTHER"
            ]
          }
        },
        "required": [
          "amount",
          "type",
          "userId"
        ]
      },
      "PaymentDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int64"
          },
          "userId": {
            "type": "integer",
            "format": "int64"
          },
          "borrowingRecordId": {
            "type": "integer",
            "format": "int64"
          },
          "amount": {
            "type": "number"
          },
          "type": {
            "type": "string",
            "enum": [
              "LATE_FEE",
              "RESERVATION_FEE",
              "LOST_BOOK_CHARGE",
              "OTHER"
            ]
          },
          "status": {
            "type": "string",
            "enum": [
              "PENDING",
              "PAID",
              "FAILED",
              "REFUNDED"
            ]
          },
          "paymentDate": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "NotificationDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int64"
          },
          "userId": {
            "type": "integer",
            "format": "int64"
          },
          "type": {
            "type": "string"
          },
          "message": {
            "type": "string"
          },
          "bookId": {
            "type": "integer",
            "format": "int64"
          },
          "bookTitle": {
            "type": "string"
          },
          "read": {
            "type": "boolean"
          },
          "timestamp": {
            "type": "string",
            "format": "date-time"
          }
